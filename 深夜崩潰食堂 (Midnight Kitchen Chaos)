<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>深夜崩潰食堂 Online - 豪華版</title>
    <style>
        body { background-color: #1a1a2e; color: #e94560; font-family: 'STHeiti', 'Microsoft JhengHei', Courier, monospace; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; padding: 20px; box-sizing: border-box; }
        
        /* 整體容器放大 */
        #game-container { background: #16213e; padding: 50px; border-radius: 25px; box-shadow: 0 0 40px rgba(0,0,0,0.7); width: 90%; max-width: 1000px; /* 最大寬度加大 */ text-align: center; border: 4px solid #0f3460; }
        
        /* 標題放大 */
        h1 { color: #f1c40f; text-shadow: 4px 4px #c0392b; font-size: 3.5rem; margin-top: 0; }
        
        /* 數值區放大 */
        .stats { display: flex; justify-content: space-around; margin-bottom: 40px; font-weight: bold; color: #4ecca3; font-size: 1.8rem; /* 字體放大 */ border-bottom: 2px solid #0f3460; padding-bottom: 20px; }
        .stat-danger { color: #e74c3c; animation: blink 1s infinite; }

        /* 故事文字放大 */
        #story { font-size: 2.2rem; /* 字體大幅放大 */ margin-bottom: 40px; min-height: 150px; color: #ffffff; line-height: 1.6; text-align: left; /* 靠左對齊方便閱讀長文 */ padding: 0 20px; }
        
        /* 按鈕區與按鈕放大 */
        #actions { display: flex; flex-direction: column; /* 按鈕垂直排列，看起來更有氣勢 */ align-items: center; gap: 20px; }
        button { background: #e94560; color: white; border: none; padding: 20px 40px; border-radius: 12px; cursor: pointer; font-size: 1.8rem; /* 按鈕文字放大 */ transition: 0.3s; width: 100%; /* 按鈕寬度撐滿 */ max-width: 600px; box-shadow: 0 5px 0 #8e2a3a; font-weight: bold; }
        button:hover { background: #c0392b; transform: translateY(-3px); box-shadow: 0 8px 0 #8e2a3a; }
        button:active { transform: translateY(2px); box-shadow: 0 2px 0 #8e2a3a; }
        button:disabled { background: #555; cursor: not-allowed; box-shadow: none; transform: none; }

        /* 結局文字樣式 */
        .end-title { font-size: 3rem; font-weight: bold; margin-top: 30px; }
        .success { color: #2ecc71; }
        .failure { color: #e74c3c; }

        @keyframes blink { 50% { opacity: 0.5; } }
    </style>
</head>
<body>

<div id="game-container">
    <h1>👨‍🍳 深夜崩潰食堂</h1>
    <div class="stats">
        <div>壓力值: <span id="stress">0</span> / 100</div> <div>得分: <span id="score">0</span></div>
    </div>
    <div id="story"></div>
    <div id="actions">
        <button id="btnA" onclick="makeChoice('A')"></button>
        <button id="btnB" onclick="makeChoice('B')"></button>
        <button id="btnRestart" onclick="location.reload()" style="display:none; background:#3498db; box-shadow: 0 5px 0 #2980b9;">🔄 重新開店</button>
    </div>
</div>

<script>
    // 遊戲數據：題目與邏輯
    const gameState = {
        stress: 0,
        score: 0,
        currentStep: 0,
        maxStress: 100,
        levels: [
            {
                story: "【關卡 1：點餐危機】<br>凌晨兩點，雨超級大。一位滿身大汗的上班族衝進來大喊：『給我最快的東西！我要趕末班車！』",
                btnA: "A: 現炒炒飯 (高品質，耗時5分鐘)",
                btnB: "B: 昨天的冷泡麵 (極速，但難吃)",
                choiceA: { stress: -10, score: 30, next: "🍳 客人感動到流淚，壓力大幅降低！" },
                choiceB: { stress: 25, score: 5, next: "🤮 客人吃到麵心是硬的，當場翻桌！" }
            },
            {
                story: "【關卡 2：突發狀況】<br>剛送走客人，廚房突然傳出巨響！",
                btnA: "A: 冷靜拿起滅火器檢查",
                btnB: "B: 跟著尖叫並抱頭蹲下",
                choiceA: { stress: 5, score: 40, next: "😎 只是微波爐炸開，你迅速化解危機。" },
                choiceB: { stress: 40, score: 0, next: "😱 廚房陷入混亂，路過的巡警進來查看。" }
            },
            {
                story: "【關卡 3：奧客登場】<br>一位自稱美食評論家的客人坐下，點了一碗麵，吃了一口就皺眉：『這味道太淡了，我要見主廚！』",
                btnA: "A: 誠懇道歉，重做一碗 (耗時耗材)",
                btnB: "B: 拿出鹽巴大喊：『自己加！』",
                choiceA: { stress: 15, score: 50, next: "👨‍🍳 他勉強滿意，給了中評。" },
                choiceB: { stress: 35, score: -20, next: "🤬 他氣炸了，在 Google 給了一星負評！" }
            },
            {
                story: "【關卡 4：神祕客】<br>一位穿著黑西裝、戴墨鏡的大漢走進來，放下一個皮箱：『包場。把你們最貴的菜都上來。』",
                btnA: "A: 拿出傳說中的黃金戰斧牛排",
                btnB: "B: 顫抖地說：『對不起，我們只有泡麵...』",
                choiceA: { stress: 20, score: 150, next: "💰 他很滿意，留下大筆小費！" },
                choiceB: { stress: 10, score: 20, next: "🕴️ 他嘖了一聲，失望地離開了。" }
            },
            {
                story: "【關卡 5：最終考驗】<br>下班時間到了，門口卻突然排起長龍，原來是剛看完演唱會的群眾...",
                btnA: "A: 咬牙繼續營業 (賺大錢但超累)",
                btnB: "B: 無情拉下鐵門 (休息是為了走更遠的路)",
                choiceA: { stress: 50, score: 200, next: "🥳 賺翻了！但你累到快升天。" },
                choiceB: { stress: -30, score: 0, next: "💤 你安穩地睡了個好覺。" }
            }
        ]
    };

    const storyEl = document.getElementById('story');
    const stressEl = document.getElementById('stress');
    const scoreEl = document.getElementById('score');
    const btnA = document.getElementById('btnA');
    const btnB = document.getElementById('btnB');
    const btnRestart = document.getElementById('btnRestart');

    function updateDisplay() {
        const currentLevel = gameState.levels[gameState.currentStep];
        storyEl.innerHTML = currentLevel.story;
        btnA.innerText = currentLevel.btnA;
        btnB.innerText = currentLevel.btnB;
        
        stressEl.innerText = gameState.stress;
        scoreEl.innerText = gameState.score;

        // 壓力過高警示
        if (gameState.stress >= gameState.maxStress * 0.8) {
            stressEl.parentElement.classList.add('stat-danger');
        } else {
            stressEl.parentElement.classList.remove('stat-danger');
        }
    }

    function makeChoice(choice) {
        const currentLevel = gameState.levels[gameState.currentStep];
        const result = (choice === 'A') ? currentLevel.choiceA : currentLevel.choiceB;

        gameState.stress += result.stress;
        gameState.score += result.score;
        gameState.currentStep++;

        // 檢查是否倒閉
        if (gameState.stress >= gameState.maxStress) {
            endGame(false, result.next + "<br><br>🤯 你的壓力爆表，心臟受不了，食堂當場倒閉！");
            return;
        }

        // 檢查是否通關
        if (gameState.currentStep >= gameState.levels.length) {
            endGame(true, result.next + "<br><br>🏁 撐過今晚了！結算時間...");
        } else {
            // 顯示過場文字，1.5秒後切換下一關
            storyEl.innerHTML = result.next;
            btnA.disabled = true;
            btnB.disabled = true;
            setTimeout(() => {
                btnA.disabled = false;
                btnB.disabled = false;
                updateDisplay();
            }, 1500);
        }
    }

    function endGame(isWin, finalText) {
        // 更新最終數值
        stressEl.innerText = Math.max(0, gameState.stress);
        scoreEl.innerText = gameState.score;
        btnA.style.display = 'none';
        btnB.style.display = 'none';
        btnRestart.style.display = 'block';

        if (!isWin) {
            storyEl.innerHTML = finalText + "<div class='end-title failure'>💀 評價：地獄廚神（倒閉）</div>";
        } else {
            let evaluation = "";
            if (gameState.score >= 350) evaluation = "<div class='end-title success'>🌟 評價：深夜守護神（傳奇級）</div>";
            else if (gameState.score >= 200) evaluation = "<div class='end-title success'>😊 評價：社區好鄰居（穩定級）</div>";
            else evaluation = "<div class='end-title failure'>😕 評價：勉強糊口（菜鳥級）</div>";
            
            storyEl.innerHTML = finalText + evaluation + `<br>最終得分: ${gameState.score}`;
        }
    }

    // 初始化遊戲
    updateDisplay();
</script>

</body>
</html>
