<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>深夜食堂：命運分支 - 終極版</title>
    <style>
        :root { --main-red: #e94560; --bg-dark: #1a1a2e; --panel-bg: #16213e; --accent: #4ecca3; --gold: #f1c40f; }
        body { background-color: var(--bg-dark); color: white; font-family: 'Segoe UI', 'Microsoft JhengHei', sans-serif; margin: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh; overflow-x: hidden; }
        
        #game-container { background: var(--panel-bg); width: 95%; max-width: 900px; padding: 40px; border-radius: 30px; border: 3px solid #0f3460; box-shadow: 0 0 50px rgba(0,0,0,0.8); position: relative; }

        /* 地圖系統 */
        .map-container { display: flex; justify-content: space-between; margin-bottom: 30px; padding: 10px; background: rgba(0,0,0,0.3); border-radius: 15px; position: relative; }
        .node { width: 40px; height: 40px; background: #333; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; position: relative; z-index: 2; transition: 0.5s; border: 2px solid #555; }
        .node.active { background: var(--gold); color: black; box-shadow: 0 0 15px var(--gold); border-color: white; }
        .node.passed { background: var(--accent); color: black; }
        .map-line { position: absolute; top: 30px; left: 5%; width: 90%; height: 2px; background: #444; z-index: 1; }

        /* 數值條 */
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .progress-bar-bg { width: 200px; height: 15px; background: #333; border-radius: 10px; overflow: hidden; border: 1px solid #555; }
        #stress-fill { height: 100%; width: 0%; background: linear-gradient(90deg, #4ecca3, #e94560); transition: 0.5s; }

        /* 故事內容 */
        #story-box { min-height: 200px; margin-bottom: 30px; }
        #story-text { font-size: 1.8rem; line-height: 1.5; color: #fff; margin-bottom: 20px; }
        #result-text { font-size: 1.3rem; color: var(--accent); min-height: 1.5em; font-style: italic; }

        /* 按鈕互動 */
        .btn-group { display: grid; gap: 15px; }
        button { background: var(--main-red); color: white; border: none; padding: 18px; border-radius: 12px; font-size: 1.4rem; cursor: pointer; transition: 0.2s; font-weight: bold; box-shadow: 0 4px 0 #8e2a3a; }
        button:hover { filter: brightness(1.2); transform: translateY(-2px); }
        button:active { transform: translateY(2px); box-shadow: none; }
        button:disabled { background: #444; box-shadow: none; cursor: not-allowed; opacity: 0.6; }

        /* 特效 */
        .shake { animation: shake 0.5s; }
        @keyframes shake { 0% { transform: translate(1px, 1px) rotate(0deg); } 20% { transform: translate(-3px, 0px) rotate(-1deg); } 50% { transform: translate(-1px, 2px) rotate(1deg); } 100% { transform: translate(0px, 0px) rotate(0deg); } }
    </style>
</head>
<body>

<div id="game-container">
    <div class="map-container">
        <div class="map-line"></div>
        <div class="node active" id="node0">1</div>
        <div class="node" id="node1">2</div>
        <div class="node" id="node2">3</div>
        <div class="node" id="node3">4</div>
        <div class="node" id="node4">🏁</div>
    </div>

    <div class="header">
        <div>
            <span>🔥 壓力指數</span>
            <div class="progress-bar-bg"><div id="stress-fill"></div></div>
        </div>
        <div style="font-size: 1.5rem;">💰 金幣: <span id="score-val" style="color:var(--gold)">0</span></div>
    </div>

    <div id="story-box">
        <div id="story-text">載入中...</div>
        <div id="result-text"></div>
    </div>

    <div class="btn-group">
        <button id="optA" onclick="choose('A')"></button>
        <button id="optB" onclick="choose('B')"></button>
    </div>
</div>

<script>
    const data = {
        stress: 0, score: 0, currentStep: 0,
        storyline: [
            { // Step 0
                text: "深夜 2:00。一對吵架的情侶衝進店裡，女生哭著要吃甜的，男生暴躁地要抽菸。",
                A: "特製蜂蜜厚片 (安撫情緒)",
                B: "大喊：店內禁菸！要吵出去吵！",
                onA: { stress: 5, score: 20, next: "💖 女生破涕為笑，氣氛緩和了。你似乎開啟了『溫馨經營』路線。", branch: "warm" },
                onB: { stress: 20, score: 0, next: "💢 男生踹了桌子一腳離開。你感到頭痛。這注定是個『硬派之夜』。", branch: "hard" }
            },
            { // Step 1 (分歧點)
                text: "一名神祕老頭走進來，說他可以用寶物換一頓飯。",
                warm: {
                    A: "免費請他吃熱麵 (施比受更有福)",
                    B: "拒絕，這不是慈善機構",
                    onA: { stress: -10, score: 50, next: "✨ 老頭給了你一張黃金食譜！" },
                    onB: { stress: 10, score: 0, next: "👴 老頭失望離開，你心裡怪怪的。" }
                },
                hard: {
                    A: "問他有沒有值錢的情報",
                    B: "叫他滾，別擋著做生意",
                    onA: { stress: 10, score: 100, next: "🕵️ 他透露了今晚黑幫收費的消息！" },
                    onB: { stress: -5, score: 0, next: "🚪 店裡清靜多了。" }
                }
            },
            { // Step 2
                text: "一群喝醉的壯漢進來，要求點選菜單上沒有的『地獄特餐』。",
                A: "把廚房剩下的食材亂燉一通",
                B: "堅持只照菜單出餐",
                onA: { stress: 25, score: 80, next: "🤢 他們竟然覺得很好吃？這真是奇蹟。" },
                onB: { stress: 10, score: 40, next: "🙄 他們抱怨連連，但還是付了錢。" }
            },
            { // Step 3
                text: "最後一刻，你的競爭對手（斜對面店主）走進來，臉色慘白說他廚房失火了，求你收留他的客人。",
                A: "大方接手 (壓力爆棚但聲望滿載)",
                B: "冷嘲熱諷並關門大吉",
                onA: { stress: 40, score: 300, next: "🔥 你忙瘋了！但今晚你成了整條街的英雄！" },
                onB: { stress: -20, score: -50, next: "🤐 雖然輕鬆，但名聲似乎變臭了。" }
            }
        ]
    };

    let branch = "warm";

    function updateUI(resultText = "") {
        const step = data.storyline[data.currentStep];
        const content = (data.currentStep > 0 && step[branch]) ? step[branch] : step;

        document.getElementById('story-text').innerText = content.text;
        document.getElementById('optA').innerText = content.A;
        document.getElementById('optB').innerText = content.B;
        document.getElementById('result-text').innerText = resultText;
        
        // 更新數據
        document.getElementById('score-val').innerText = data.score;
        document.getElementById('stress-fill').style.width = data.stress + "%";
        
        // 更新地圖
        document.querySelectorAll('.node').forEach((n, i) => {
            n.classList.remove('active', 'passed');
            if(i === data.currentStep) n.classList.add('active');
            if(i < data.currentStep) n.classList.add('passed');
        });

        if (data.stress >= 80) document.getElementById('game-container').classList.add('shake');
        else document.getElementById('game-container').classList.remove('shake');
    }

    function choose(opt) {
        const step = data.storyline[data.currentStep];
        const content = (data.currentStep > 0 && step[branch]) ? step[branch] : step;
        const res = (opt === 'A') ? content.onA : content.onB;

        data.stress += res.stress;
        data.score += res.score;
        if(res.branch) branch = res.branch;

        if (data.stress >= 100) return endGame("🤯 壓力炸裂！你當場解下圍裙棄店逃跑了。");
        
        data.currentStep++;
        if (data.currentStep >= data.storyline.length) {
            let finalMsg = data.score > 400 ? "🏆 傳奇大廚！你讓這條街重獲新生。" : "平淡收場，這就是人生。";
            return endGame(finalMsg);
        }

        updateUI(res.next);
    }

    function endGame(msg) {
        document.getElementById('story-box').innerHTML = `<h2 style="font-size:3rem; color:var(--gold)">結局</h2><p style="font-size:2rem">${msg}</p>`;
        document.querySelector('.btn-group').innerHTML = `<button onclick="location.reload()">重新挑戰</button>`;
        document.getElementById('node4').classList.add('active');
    }

    updateUI();
</script>

</body>
</html>
